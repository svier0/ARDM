{
	"name": "ardm",
	"version": "1.0.0",
	"type": "module",
	"description": "Another Redis Desktop Manager - A Redis GUI built with Electrobun",
	"scripts": {
		"start": "electrobun dev",
		"dev": "electrobun dev --watch",
		"build:canary": "electrobun build --env=canary",
		"build:portable": "bun run scripts/build-portable.ts"
	},
	"dependencies": {
		"electrobun": "1.18.1",
		"ioredis": "^5.11.1",
		"ssh2": "^1.17.0",
		"tunnel-ssh": "^5.2.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.7.2"
	}
}
